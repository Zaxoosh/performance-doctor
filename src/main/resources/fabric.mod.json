  "authors": [
    "Zaxoosh"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/performance-doctor",
    "sources": "https://github.com/Zaxoosh/performance-doctor",
    "issues": "https://github.com/Zaxoosh/performance-doctor/issues"
  },
  "license": "MIT",
  "environment": "server",
  "entrypoints": {
    "main": [
      "dev.zaxoosh.performancedoctor.PerformanceDoctorMod"
    ]
  },
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "fabric-api": "*"
  }
}
